@model Enrollment
@{
    ViewData["Title"] = "Enroll Student";
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Enrollment management</span>
        <h1>Enroll student</h1>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index">Back</a>
</div>

<section class="panel form-panel">
    <form asp-action="Create" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="CourseId" class="form-label"></label>
                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.Courses">
                    <option value="">Choose course</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="StudentId" class="form-label"></label>
                <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                    <option value="">Choose student</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="CompletionPercentage" class="form-label"></label>
                <input asp-for="CompletionPercentage" class="form-control" />
                <span asp-validation-for="CompletionPercentage" class="text-danger"></span>
            </div>
        </div>
        <button class="btn btn-primary mt-4" type="submit">Save Enrollment</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
