@model StudentDashboardViewModel
@{
    ViewData["Title"] = "Student Dashboard";
    var performanceLabel = PerformanceLabelHelper.GetLabel(Model.AverageScore);
    var progressLabels = string.Join(",", Model.CourseProgress.Keys.Select(ChartLabelHelper.GetShortCourseLabel));
    var progressFullLabels = string.Join(",", Model.CourseProgress.Keys);
    var progressValues = string.Join(",", Model.CourseProgress.Values);
    var scoreLabels = string.Join(",", Model.RecentScores.Select(s => ChartLabelHelper.GetShortAssessmentLabel(s.Assessment?.Title ?? "Assessment")));
    var scoreFullLabels = string.Join(",", Model.RecentScores.Select(s => s.Assessment?.Title ?? "Assessment"));
    var scoreValues = string.Join(",", Model.RecentScores.Select(s => s.Score));
    var nextAssessment = Model.Assessments.FirstOrDefault();
    var nextLesson = Model.Courses
        .SelectMany(course => course.Lessons.Select(lesson => new { Lesson = lesson, Course = course }))
        .OrderByDescending(item => item.Lesson.IsAvailableOffline)
        .ThenByDescending(item => item.Lesson.DateCreated)
        .FirstOrDefault();
    var needsReview = Model.AverageScore > 0 && Model.AverageScore < 75;
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Student Dashboard</span>
        <h1>Your learning progress</h1>
        <p>View your courses, assessments, scores, and offline learning materials.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Assessments" asp-action="Index">Take Assessment</a>
</div>

<section class="panel mb-4">
    <h2>Next Best Action</h2>
    <div class="next-actions">
        @if (nextAssessment != null)
        {
            <div class="action-card">
                <div>
                    <strong>Next: Take @nextAssessment.Title</strong>
                    <p>@nextAssessment.Course?.Title - Due @nextAssessment.DueDate.ToString("MMM dd, yyyy")</p>
                </div>
                <a class="btn btn-primary btn-sm" asp-controller="Assessments" asp-action="Take" asp-route-id="@nextAssessment.AssessmentId">Start Assessment</a>
            </div>
        }
        @if (nextLesson != null)
        {
            <div class="action-card">
                <div>
                    <strong>Next: Read @nextLesson.Lesson.Title</strong>
                    <p>@nextLesson.Course.Title @(nextLesson.Lesson.IsAvailableOffline ? "- Available Offline" : "- Needs Internet")</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Lessons" asp-action="Details" asp-route-id="@nextLesson.Lesson.LessonId">Open Lesson</a>
            </div>
        }
        @if (Model.PendingSyncSubmissions > 0)
        {
            <div class="action-card">
                <div>
                    <strong>Sync pending offline work</strong>
                    <p>@Model.PendingSyncSubmissions saved submission(s) will sync when you are back online.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Student" asp-action="OfflineLibrary">Offline Library</a>
            </div>
        }
        @if (needsReview)
        {
            <div class="action-card">
                <div>
                    <strong>Review recommended lessons</strong>
                    <p>@PerformanceLabelHelper.GetRecommendation(Model.AverageScore)</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Submissions" asp-action="Index">View Scores</a>
            </div>
        }
    </div>
</section>

<div class="stats-grid" data-dashboard-section="Course Progress">
    <a class="stat-card stat-link" asp-controller="Courses" asp-action="Index"><span>Enrolled courses</span><strong>@Model.EnrolledCourses</strong></a>
    <a class="stat-card stat-link" asp-controller="Assessments" asp-action="Index"><span>Upcoming assessments</span><strong>@Model.UpcomingAssessments</strong></a>
    <a class="stat-card stat-link" asp-controller="Submissions" asp-action="Index"><span>Average score</span><strong>@Model.AverageScore.ToString("0.##")%</strong></a>
    <a class="stat-card stat-link" asp-controller="Reports" asp-action="StudentPerformance"><span>Progress status</span><strong><span class="badge @PerformanceLabelHelper.GetBadgeClass(Model.AverageScore)">@performanceLabel</span></strong></a>
    <a class="stat-card stat-link" asp-controller="Reports" asp-action="StudentPerformance"><span>Progress</span><strong>@Model.ProgressPercentage.ToString("0.##")%</strong></a>
    <a class="stat-card stat-link" asp-controller="Student" asp-action="OfflineLibrary"><span>Offline lessons</span><strong>@Model.OfflineAvailableLessons</strong></a>
    <a class="stat-card stat-link" asp-controller="Student" asp-action="OfflineLibrary"><span>Pending sync</span><strong>@Model.PendingSyncSubmissions</strong></a>
</div>

<div class="quick-action-heading">Notification Center</div>
<section class="notification-strip" aria-label="Learning notifications">
    <div><strong>New assessment posted</strong><span>Check the upcoming application quizzes for your enrolled courses.</span></div>
    <div><strong>New lesson available</strong><span>Offline-ready lessons are available in your learning library.</span></div>
    <div><strong>Score released</strong><span>Your recent quiz scores are available below.</span></div>
    <div><strong>Offline sync status</strong><span>@(Model.PendingSyncSubmissions > 0 ? "You have pending offline work to sync." : "All saved submissions are synced.")</span></div>
</section>

<section class="panel mb-4">
    <h2>Recent Activity</h2>
    <div class="activity-timeline">
        @if (Model.RecentScores.Any())
        {
            @foreach (var item in Model.RecentScores.Take(3))
            {
                <div class="timeline-item">
                    <strong>Score released: @item.Assessment?.Title</strong>
                    <p>@item.Score.ToString("0.##")% - @PerformanceLabelHelper.GetRecommendation(item.Score)</p>
                </div>
            }
        }
        @if (nextLesson != null)
        {
            <div class="timeline-item">
                <strong>Lesson available: @nextLesson.Lesson.Title</strong>
                <p>@nextLesson.Course.Title @(nextLesson.Lesson.IsAvailableOffline ? "is ready for offline review." : "is available online.")</p>
            </div>
        }
        @if (!Model.RecentScores.Any() && nextLesson == null)
        {
            <p class="empty-copy">Your learning activity will appear here after lessons, scores, and assessments are posted.</p>
        }
    </div>
</section>

<div class="dashboard-grid">
    <section class="panel" data-dashboard-section="Course Progress">
        <h2>Course Progress Overview</h2>
        @if (!Model.CourseProgress.Any())
        {
            <p class="empty-copy">No progress data yet. Complete lessons and assessments to generate your progress chart.</p>
        }
        else
        {
            <canvas class="analytics-chart" data-chart="horizontalBar" data-title="Course Progress Overview" data-labels="@progressLabels" data-full-labels="@progressFullLabels" data-values="@progressValues" data-scale-max="100" data-tooltip-label="Progress" data-empty="No progress data yet. Complete lessons and assessments to generate your progress chart." height="320"></canvas>
        }
    </section>
    <section class="panel" data-dashboard-section="Upcoming Assessments">
        <h2>Upcoming assessments</h2>
        @if (!Model.Assessments.Any())
        {
            <p class="empty-copy">No assessments available yet. Please check again after your teacher posts a quiz.</p>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.Assessments)
                {
                    <div>
                        <strong>@item.Title</strong>
                        <span>@item.Course?.Title - Due @item.DueDate.ToString("MMM dd, yyyy")</span>
                    </div>
                }
            </div>
        }
    </section>
</div>

<div class="dashboard-grid mt-4">
    <section class="panel" data-dashboard-section="Recent Scores">
        <h2>Recent Assessment Scores</h2>
        @if (!Model.RecentScores.Any())
        {
            <p class="empty-copy">No assessment scores yet. Complete an assessment to see your score trend.</p>
        }
        else
        {
            <canvas class="analytics-chart" data-chart="bar" data-title="Assessment Score Summary" data-labels="@scoreLabels" data-full-labels="@scoreFullLabels" data-values="@scoreValues" data-scale-max="100" data-tooltip-label="Score" data-empty="No assessment scores yet. Complete an assessment to see your score trend." height="260"></canvas>
        }
    </section>
    <section class="panel" data-dashboard-section="Offline Lessons">
        <h2>Completion Status</h2>
        <canvas class="analytics-chart" data-chart="doughnut" data-title="Completion Status" data-labels="Completed,Remaining" data-values="@Model.CompletedAssessments,@Model.RemainingAssessments" data-empty="No completion data yet. Start an assessment to build your completion status." height="260"></canvas>
    </section>
</div>

<section class="panel mt-4" data-dashboard-section="Recent Scores">
    <h2>Recent scores</h2>
    @if (!Model.RecentScores.Any())
    {
        <p class="empty-copy">No scores yet. Complete an assessment to view your performance and recommendations.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead><tr><th>Assessment</th><th>Course</th><th>Score</th><th>Performance</th><th>Status</th><th>Recommendation</th></tr></thead>
                <tbody>
                    @foreach (var score in Model.RecentScores)
                    {
                        var badgeClass = score.Status == SubmissionStatus.Synced ? "text-bg-success" : "text-bg-warning";
                        var label = PerformanceLabelHelper.GetLabel(score.Score);

                        <tr>
                            <td>@score.Assessment?.Title</td>
                            <td>@score.Assessment?.Course?.Title</td>
                            <td>@score.Score.ToString("0.##")%</td>
                            <td><span class="badge @PerformanceLabelHelper.GetBadgeClass(score.Score)">@label</span></td>
                            <td><span class="badge @badgeClass">@score.Status</span></td>
                            <td>@PerformanceLabelHelper.GetRecommendation(score.Score)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
