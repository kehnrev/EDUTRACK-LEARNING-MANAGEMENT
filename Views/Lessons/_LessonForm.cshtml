@model Lesson

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="CourseId" class="form-label">Select Course <span class="text-danger">*</span></label>
        <select asp-for="CourseId" class="form-select" asp-items="ViewBag.Courses">
            <option value="">Choose course</option>
        </select>
        <div class="form-text">Choose the Senior High School class that should receive this lecture.</div>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Title" class="form-label">Lecture Title <span class="text-danger">*</span></label>
        <input asp-for="Title" class="form-control" />
        <div class="form-text">Use a clear title students can recognize on their Lessons page.</div>
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Content" class="form-label">Lecture Content <span class="text-danger">*</span></label>
        <textarea asp-for="Content" class="form-control" rows="8"></textarea>
        <div class="form-text">Add the main explanation, reading guide, or activity instructions for students.</div>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label class="form-label" for="materialFile">Upload Learning Material</label>
        <input class="form-control" id="materialFile" name="materialFile" type="file" accept=".pdf,.doc,.docx,.ppt,.pptx,.txt" />
        <span class="text-danger">@Html.ValidationMessage("materialFile")</span>
        <div class="form-text">Optional. PDF, Word, PowerPoint, and text files only. Maximum size: 10 MB.</div>
        @if (!string.IsNullOrWhiteSpace(Model.OriginalFileName) && !string.IsNullOrWhiteSpace(Model.FilePath))
        {
            <div class="current-material mt-2">
                <strong>Current file:</strong>
                <a asp-controller="Lessons" asp-action="Material" asp-route-id="@Model.LessonId" target="_blank" rel="noopener">@Model.OriginalFileName</a>
                <span class="text-muted">Upload a new file to replace it.</span>
            </div>
        }
    </div>
    <div class="col-md-4">
        <label asp-for="FilePath" class="form-label">Optional Learning Material Link</label>
        <input asp-for="FilePath" class="form-control" placeholder="https://example.com/material.pdf" />
        <input asp-for="OriginalFileName" type="hidden" />
        <input asp-for="ContentType" type="hidden" />
        <input asp-for="FileSize" type="hidden" />
        <span asp-validation-for="FilePath" class="text-danger"></span>
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check offline-check-panel">
            <input asp-for="IsAvailableOffline" class="form-check-input" />
            <label asp-for="IsAvailableOffline" class="form-check-label">Available Offline</label>
            <div class="offline-feedback"
                 data-offline-feedback
                 data-checked-message="This lesson will be marked as available offline."
                 data-unchecked-message="This lesson will require internet access unless downloaded separately.">
                @(Model.IsAvailableOffline
                    ? "This lesson will be marked as available offline."
                    : "This lesson will require internet access unless downloaded separately.")
            </div>
        </div>
    </div>
</div>
