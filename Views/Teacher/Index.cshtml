@model TeacherDashboardViewModel
@{
    ViewData["Title"] = "Teacher Dashboard";
    var courseAverageLabels = string.Join(",", Model.ClassAverageByCourse.Keys.Select(ChartLabelHelper.GetShortCourseLabel));
    var courseAverageFullLabels = string.Join(",", Model.ClassAverageByCourse.Keys);
    var courseAverageValues = string.Join(",", Model.ClassAverageByCourse.Values);
    var submissionLabels = string.Join(",", Model.SubmissionStatusSummary.Keys);
    var submissionValues = string.Join(",", Model.SubmissionStatusSummary.Values);
    var nextAssessment = Model.UpcomingAssessments.FirstOrDefault();
    var supportStudent = Model.StudentsNeedingImprovement.FirstOrDefault();
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Teacher dashboard</span>
        <h1>Class performance and learning activity</h1>
    </div>
    <a class="btn btn-primary" asp-controller="Courses" asp-action="Create">Create Course</a>
</div>

<div class="quick-action-heading">Quick actions</div>
<div class="quick-actions">
    <a class="btn btn-primary" asp-controller="Courses" asp-action="Create">Create Course</a>
    <a class="btn btn-outline-primary" asp-controller="Lessons" asp-action="Create">Add Lecture / Lesson</a>
    <a class="btn btn-outline-primary" asp-controller="Assessments" asp-action="Create">Create Assessment</a>
    <a class="btn btn-outline-primary" asp-controller="Teacher" asp-action="ClassList">Class List</a>
    <a class="btn btn-outline-primary" asp-controller="Teacher" asp-action="StudentProgress">Student Progress</a>
    <a class="btn btn-outline-primary" asp-controller="Reports" asp-action="ClassPerformance">Teacher Reports</a>
    <a class="btn btn-outline-primary" asp-controller="Announcements" asp-action="Create">Post Announcement</a>
</div>

<section class="panel mb-4">
    <h2>Next Best Action</h2>
    <div class="next-actions">
        @if (Model.PendingSubmissions > 0)
        {
            <div class="action-card">
                <div>
                    <strong>Next: Review @Model.PendingSubmissions pending submissions</strong>
                    <p>Check missing or recently submitted assessments so students receive timely feedback.</p>
                </div>
                <a class="btn btn-primary btn-sm" asp-controller="Submissions" asp-action="Index">View Submissions</a>
            </div>
        }
        @if (supportStudent != null)
        {
            <div class="action-card">
                <div>
                    <strong>Follow up with @supportStudent.FullName</strong>
                    <p>Student appears in the support list because of low scores, missing work, or low progress.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Teacher" asp-action="StudentProgress">View Progress</a>
            </div>
        }
        @if (nextAssessment != null)
        {
            <div class="action-card">
                <div>
                    <strong>Upcoming: @nextAssessment.Title</strong>
                    <p>@nextAssessment.Course?.Title - Due @nextAssessment.DueDate.ToString("MMM dd, yyyy")</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Assessments" asp-action="Details" asp-route-id="@nextAssessment.AssessmentId">Open</a>
            </div>
        }
        @if (Model.CoursesMissingLearningMaterials > 0)
        {
            <div class="action-card">
                <div>
                    <strong>Add learning materials</strong>
                    <p>@Model.CoursesMissingLearningMaterials course(s) still need a lecture or lesson.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Lessons" asp-action="Create">Add Lecture</a>
            </div>
        }
        @if (Model.PendingSubmissions == 0 && supportStudent == null && nextAssessment == null && Model.CoursesMissingLearningMaterials == 0)
        {
            <div class="action-card">
                <div>
                    <strong>Keep classes moving</strong>
                    <p>Create a new lecture or assessment when the next topic is ready.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Lessons" asp-action="Create">Add Lecture</a>
            </div>
        }
    </div>
</section>

<div class="stats-grid" data-dashboard-section="Pending Submissions">
    <a class="stat-card stat-link" asp-controller="Courses" asp-action="Index"><span>My courses</span><strong>@Model.MyCourses</strong></a>
    <a class="stat-card stat-link" asp-controller="Teacher" asp-action="ClassList"><span>Students enrolled</span><strong>@Model.TotalStudentsEnrolled</strong></a>
    <a class="stat-card stat-link" asp-controller="Lessons" asp-action="Index"><span>Total lessons</span><strong>@Model.TotalLessonsCreated</strong></a>
    <a class="stat-card stat-link" asp-controller="Assessments" asp-action="Index"><span>Total assessments</span><strong>@Model.TotalAssessmentsCreated</strong></a>
    <a class="stat-card stat-link" asp-controller="Submissions" asp-action="Index"><span>Pending submissions</span><strong>@Model.PendingSubmissions</strong></a>
    <a class="stat-card stat-link" asp-controller="Reports" asp-action="ClassPerformance"><span>Average class score</span><strong>@Model.AverageClassScore.ToString("0.##")%</strong></a>
    <a class="stat-card stat-link" asp-controller="Teacher" asp-action="StudentProgress"><span>Class status</span><strong><span class="badge @PerformanceLabelHelper.GetBadgeClass(Model.AverageClassScore)">@PerformanceLabelHelper.GetLabel(Model.AverageClassScore)</span></strong></a>
</div>

<div class="quick-action-heading">Notification Center</div>
<section class="notification-strip" aria-label="Teacher notifications">
    <div><strong>Announcement posted</strong><span>Recent announcements are visible to enrolled learners.</span></div>
    <div><strong>New lesson available</strong><span>Offline-ready materials help students continue learning without internet.</span></div>
    <div><strong>New assessment posted</strong><span>Upcoming quizzes are listed in student dashboards.</span></div>
    <div><strong>File uploaded successfully</strong><span>Uploaded materials appear on student lesson pages.</span></div>
</section>

<section class="panel mb-4">
    <h2>Recent Activity</h2>
    <div class="activity-timeline">
        @if (Model.RecentSubmissions.Any())
        {
            @foreach (var item in Model.RecentSubmissions.Take(4))
            {
                <div class="timeline-item">
                    <strong>@item.Student?.FullName submitted @item.Assessment?.Title</strong>
                    <p>@item.Score.ToString("0.##")% - @item.SubmittedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")</p>
                </div>
            }
        }
        @if (Model.RecentAssessments.Any())
        {
            @foreach (var item in Model.RecentAssessments.Take(2))
            {
                <div class="timeline-item">
                    <strong>Assessment created: @item.Title</strong>
                    <p>@item.Course?.Title - Due @item.DueDate.ToString("MMM dd, yyyy")</p>
                </div>
            }
        }
        @if (!Model.RecentSubmissions.Any() && !Model.RecentAssessments.Any())
        {
            <p class="empty-copy">Class activity will appear here after assessments, submissions, and lessons are added.</p>
        }
    </div>
</section>

<div class="dashboard-grid">
    <section class="panel" data-dashboard-section="Class Performance">
        <h2>Class Average by Course</h2>
        @if (!Model.ClassAverageByCourse.Any())
        {
            <p class="empty-copy">No class score data yet. Students need to complete assessments before averages appear.</p>
        }
        else
        {
            <canvas class="analytics-chart" data-chart="horizontalBar" data-title="Class Average by Course" data-labels="@courseAverageLabels" data-full-labels="@courseAverageFullLabels" data-values="@courseAverageValues" data-scale-max="100" data-tooltip-label="Average" data-empty="No class score data yet. Students need to complete assessments before averages appear." height="320"></canvas>
        }
    </section>
    <section class="panel" data-dashboard-section="Students Needing Support">
        <h2>Students Needing Support</h2>
        @if (!Model.StudentsNeedingImprovement.Any())
        {
            <p class="empty-copy">No at-risk learners found from current data.</p>
        }
        else
        {
            <div class="list-stack">
                @foreach (var student in Model.StudentsNeedingImprovement.Take(6))
                {
                    <div>
                        <strong>@student.FullName</strong>
                        <span>@student.Email - low scores, missing submissions, or low course progress</span>
                    </div>
                }
            </div>
        }
    </section>
</div>

<section class="panel mt-4" data-dashboard-section="Pending Submissions">
    <h2>Assessment Submission Status</h2>
    <canvas class="analytics-chart" data-chart="doughnut" data-title="Assessment Submission Status" data-labels="@submissionLabels" data-values="@submissionValues" data-empty="No submission status data yet." height="260"></canvas>
</section>

<div class="dashboard-grid mt-4">
    <section class="panel" data-dashboard-section="Recent Submissions">
        <h2>Recent student submissions</h2>
        @if (!Model.RecentSubmissions.Any())
        {
            <p class="empty-copy">No submissions yet. Student results will appear here after assessments are submitted.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Student</th><th>Assessment</th><th>Score</th><th>Date</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.RecentSubmissions)
                        {
                            <tr>
                                <td>@item.Student?.FullName</td>
                                <td>@item.Assessment?.Title</td>
                                <td><span class="badge @PerformanceLabelHelper.GetBadgeClass(item.Score)">@item.Score.ToString("0.##")%</span></td>
                                <td>@item.SubmittedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="panel" data-dashboard-section="Upcoming Assessments">
        <h2>Upcoming assessments</h2>
        @if (!Model.UpcomingAssessments.Any())
        {
            <p class="empty-copy">No upcoming assessments yet. Create a quiz when the next lesson is ready.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Assessment</th><th>Course</th><th>Due</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.UpcomingAssessments)
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.Course?.Title</td>
                                <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-controller="Assessments" asp-action="Details" asp-route-id="@item.AssessmentId">Open</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
