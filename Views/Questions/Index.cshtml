@model IEnumerable<Question>
@{
    var assessment = ViewBag.Assessment as Assessment;
    ViewData["Title"] = "Questions";
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">@assessment?.Title</span>
        <h1>Questions</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create" asp-route-assessmentId="@assessment?.AssessmentId">Add Question</a>
</div>

<div class="table-responsive panel">
    <table class="table align-middle">
        <thead><tr><th>Question</th><th>Correct</th><th>Points</th><th></th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.QuestionText</td>
                    <td>@item.CorrectAnswer</td>
                    <td>@item.Points</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.QuestionId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.QuestionId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
