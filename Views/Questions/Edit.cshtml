@model Question
@{
    ViewData["Title"] = "Edit Question";
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Assessment builder</span>
        <h1>Edit question</h1>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index" asp-route-assessmentId="@Model.AssessmentId">Back</a>
</div>

<section class="panel form-panel">
    <form asp-action="Edit" method="post" novalidate>
        <input asp-for="QuestionId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_QuestionForm" model="Model" />
        <button class="btn btn-primary mt-4" type="submit">Update Question</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
