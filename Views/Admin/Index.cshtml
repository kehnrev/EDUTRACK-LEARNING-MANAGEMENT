@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var enrollmentLabels = string.Join(",", Model.CourseEnrollmentSummary.Keys.Select(ChartLabelHelper.GetShortCourseLabel));
    var enrollmentFullLabels = string.Join(",", Model.CourseEnrollmentSummary.Keys);
    var enrollmentValues = string.Join(",", Model.CourseEnrollmentSummary.Values);
    var passFailLabels = string.Join(",", Model.PassFailDistribution.Keys);
    var passFailValues = string.Join(",", Model.PassFailDistribution.Values);
    var latestUser = Model.RecentUsers.FirstOrDefault();
    var needsSupportCount = Model.PassFailDistribution.TryGetValue("Needs Support", out var supportCount) ? supportCount : 0;
}

<div class="dashboard-heading">
    <div>
        <span class="eyebrow">Admin dashboard</span>
        <h1>System-wide learning overview</h1>
    </div>
    <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateUser">Create User</a>
</div>

<div class="stats-grid" data-dashboard-section="System Statistics">
    <a class="stat-card stat-link" asp-controller="Admin" asp-action="Users" asp-route-role="Student"><span>Total students</span><strong>@Model.TotalStudents</strong></a>
    <a class="stat-card stat-link" asp-controller="Admin" asp-action="Users" asp-route-role="Teacher"><span>Total teachers</span><strong>@Model.TotalTeachers</strong></a>
    <a class="stat-card stat-link" asp-controller="Courses" asp-action="Index"><span>Total courses</span><strong>@Model.TotalCourses</strong></a>
    <a class="stat-card stat-link" asp-controller="Assessments" asp-action="Index"><span>Assessments</span><strong>@Model.TotalAssessments</strong></a>
    <a class="stat-card stat-link" asp-controller="Reports" asp-action="ClassPerformance"><span>Average performance</span><strong>@Model.OverallAveragePerformance.ToString("0.##")%</strong></a>
    <a class="stat-card stat-link" asp-controller="Reports" asp-action="AssessmentResults"><span>Pending sync</span><strong>@Model.PendingSyncSubmissions</strong></a>
</div>

<section class="panel mb-4">
    <h2>Next Best Action</h2>
    <div class="next-actions">
        <div class="action-card">
            <div>
                <strong>Review system reports</strong>
                <p>@Model.TotalAssessments assessments and @Model.TotalCourses courses are feeding the presentation reports.</p>
            </div>
            <a class="btn btn-primary btn-sm" asp-controller="Reports" asp-action="ClassPerformance">Open Reports</a>
        </div>
        @if (needsSupportCount > 0)
        {
            <div class="action-card">
                <div>
                    <strong>Monitor low-performing learners</strong>
                    <p>@needsSupportCount submission(s) are below the active passing score.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Reports" asp-action="StudentPerformance">Student Report</a>
            </div>
        }
        @if (latestUser != null)
        {
            <div class="action-card">
                <div>
                    <strong>Recent user activity</strong>
                    <p>@latestUser.FullName joined as @latestUser.Role.</p>
                </div>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Admin" asp-action="Users">Manage Users</a>
            </div>
        }
    </div>
</section>

@if (ViewBag.ShowDemoDataNotice != false)
{
    <div class="alert alert-info">
        <strong>Demo Data:</strong> This presentation build includes Grade 11 and Grade 12 sample users, courses, lessons, assessments, submissions, announcements, and reports.
    </div>
}

<div class="quick-action-heading">Notification Center</div>
<section class="notification-strip" aria-label="Admin notifications">
    <div><strong>Announcement posted</strong><span>Three demo announcements are available for presentation.</span></div>
    <div><strong>Score released</strong><span>Student submissions feed the analytics and printable reports.</span></div>
    <div><strong>Offline sync status</strong><span>@(Model.PendingSyncSubmissions > 0 ? "There are pending sync submissions to review." : "All offline submissions are synced.")</span></div>
</section>

<section class="panel mb-4">
    <h2>Recent Activity</h2>
    <div class="activity-timeline">
        @foreach (var user in Model.RecentUsers.Take(3))
        {
            <div class="timeline-item">
                <strong>User active: @user.FullName</strong>
                <p>@user.Role - @user.Email</p>
            </div>
        }
        @foreach (var item in Model.RecentSubmissions.Take(3))
        {
            <div class="timeline-item">
                <strong>Submission recorded: @item.Assessment?.Title</strong>
                <p>@item.Student?.FullName scored @item.Score.ToString("0.##")% in @item.Assessment?.Course?.Title.</p>
            </div>
        }
        @if (!Model.RecentUsers.Any() && !Model.RecentSubmissions.Any())
        {
            <p class="empty-copy">System activity will appear after users, submissions, and announcements are created.</p>
        }
    </div>
</section>

<div class="dashboard-grid">
    <section class="panel" data-dashboard-section="Overall Performance">
        <h2>Overall Student Performance</h2>
        <canvas class="analytics-chart" data-chart="bar" data-title="Overall Student Performance" data-labels="Average,Target" data-full-labels="Overall Average,Target Score" data-values="@Model.OverallAveragePerformance,75" data-scale-max="100" data-tooltip-label="Score" data-empty="No student performance data yet." height="260"></canvas>
    </section>
    <section class="panel" data-dashboard-section="Announcements">
        <h2>Recent announcements</h2>
        @if (!Model.RecentAnnouncements.Any())
        {
            <p class="empty-copy">No announcements yet.</p>
        }
        else
        {
            <div class="list-stack">
                @foreach (var item in Model.RecentAnnouncements)
                {
                    <div>
                        <strong>@item.Title</strong>
                        <span>@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy") by @item.CreatedBy?.FullName</span>
                    </div>
                }
            </div>
        }
    </section>
</div>

<div class="dashboard-grid mt-4">
    <section class="panel" data-dashboard-section="Reports Summary">
        <h2>Course Enrollment Summary</h2>
        <canvas class="analytics-chart" data-chart="horizontalBar" data-title="Course Enrollment Summary" data-labels="@enrollmentLabels" data-full-labels="@enrollmentFullLabels" data-values="@enrollmentValues" data-empty="No enrollment data yet." height="320"></canvas>
    </section>
    <section class="panel" data-dashboard-section="Overall Performance">
        <h2>Pass/Fail Distribution</h2>
        <canvas class="analytics-chart" data-chart="doughnut" data-title="Pass and Fail Distribution" data-labels="@passFailLabels" data-values="@passFailValues" data-empty="No pass/fail data yet." height="260"></canvas>
    </section>
</div>
