@{
    ViewData["Title"] = "About";
}

<section class="page-hero compact">
    <div class="container">
        <span class="eyebrow">About the project</span>
        <h1>Education analytics for classrooms with real connectivity challenges</h1>
        <p>
            EduTrack is an ASP.NET Core MVC learning management and performance monitoring system
            designed to help schools deliver quality education online and offline.
        </p>
    </div>
</section>

<section class="section-pad">
    <div class="container content-grid">
        <article>
            <h2>Purpose</h2>
            <p>
                The system gives teachers one place to manage courses, publish lessons, create assessments,
                score quizzes automatically, and review student progress through analytics and reports.
            </p>
        </article>
        <article>
            <h2>SDG 4 Connection</h2>
            <p>
                SDG 4 focuses on inclusive and equitable quality education. EduTrack supports this by helping
                teachers identify students who need intervention and by allowing learners to access saved
                lessons and assessments even when internet access is unstable.
            </p>
        </article>
        <article>
            <h2>How It Helps</h2>
            <p>
                Administrators see school-wide activity, teachers manage class learning, and students can
                review materials, take assessments, and monitor their own scores.
            </p>
        </article>
        <article>
            <h2>Why Offline Matters</h2>
            <p>
                Offline access reduces barriers for students in low-bandwidth homes or communities. Pending
                answers are stored locally and synced when the device reconnects.
            </p>
        </article>
    </div>
</section>
